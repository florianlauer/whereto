{
  "name": "whereto",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS=--max-old-space-size=8192 vite",
    "dev:api": "bun run --watch api/dev.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "type": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint",
    "format": "oxfmt --write src",
    "format:check": "oxfmt src",
    "db:types": "supabase gen types typescript --local > src/lib/database.types.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@hono/trpc-server": "^0.4.2",
    "@radix-ui/react-slider": "^1.3.6",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1",
    "@trpc/client": "^11.12.0",
    "@trpc/server": "^11.12.0",
    "@trpc/tanstack-react-query": "^11.12.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "deck.gl": "^9.2.10",
    "hono": "^4.12.5",
    "maplibre-gl": "^5.19.0",
    "react": "^19",
    "react-dom": "^19",
    "react-map-gl": "^8",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^3",
    "zustand": "^5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/router-plugin": "^1",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@types/geojson": "^7946.0.16",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "jsdom": "^28.1.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^6",
    "vitest": "^3"
  }
}
